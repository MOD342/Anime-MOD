{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "modPoints": { "type": "number" },
        "streakDays": { "type": "number" },
        "likesReceived": { "type": "number" },
        "commentsCount": { "type": "number" },
        "recommendationsAccepted": { "type": "number" },
        "aiGamesPoints": { "type": "number" },
        "ratingsCount": { "type": "number" },
        "chatMessagesCount": { "type": "number" },
        "lastActiveDate": { "type": "string" },
        "privacySettings": { "type": "object" },
        "avatarAlignment": { "type": "string" },
        "avatarShape": { "type": "string" },
        "bannerSize": { "type": "string" },
        "dislikesReceived": { "type": "number" },
        "approvedRecommendationsCount": { "type": "number" }
      },
      "required": ["role", "createdAt", "xp", "level", "modPoints", "streakDays", "likesReceived", "commentsCount", "recommendationsAccepted", "aiGamesPoints", "ratingsCount", "chatMessagesCount", "lastActiveDate"]
    },
    "CustomList": {
      "title": "CustomList",
      "description": "User defined custom list",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "AnimeEntry": {
      "title": "AnimeEntry",
      "description": "A user's anime entry in their library",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "posterUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["watching", "completed", "plan_to_watch", "on_hold", "dropped", "none"] },
        "releaseYear": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "episodesCount": { "type": "number" },
        "progress": { "type": "number" }
      },
      "required": ["title", "posterUrl", "status", "addedAt", "updatedAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Anime comment.",
      "type": "object",
      "properties": {
        "animeId": { "type": "string" },
        "userId": { "type": "string" },
        "userDisplayName": { "type": "string" },
        "text": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["animeId", "userId", "userDisplayName", "text", "likes", "createdAt"]
    },
    "Recommendation": {
      "title": "Recommendation",
      "description": "User recommendation for an anime.",
      "type": "object",
      "properties": {
        "animeId": { "type": "string" },
        "targetAnimeId": { "type": "string" },
        "targetAnimeTitle": { "type": "string" },
        "reason": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["animeId", "targetAnimeId", "targetAnimeTitle", "reason", "userId", "status", "createdAt"]
    },
    "Rating": {
      "title": "Rating",
      "description": "User rating for an anime.",
      "type": "object",
      "properties": {
        "animeId": { "type": "string" },
        "userId": { "type": "string" },
        "score": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["animeId", "userId", "score", "createdAt", "updatedAt"]
    },
    "GameQuestion": {
      "title": "GameQuestion",
      "description": "Cache of AI and user submitted game questions",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "questionData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "author": { "type": "string" },
        "likes": { "type": "number" },
        "dislikes": { "type": "number" }
      },
      "required": ["type", "questionData", "createdAt", "author", "likes", "dislikes"]
    },
    "AnimeTrivia": {
      "title": "AnimeTrivia",
      "description": "Multi-choice trivia questions about anime",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "options": { "type": "array" },
        "correctIndex": { "type": "number" },
        "animeName": { "type": "string" },
        "difficulty": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "author": { "type": "string" },
        "likes": { "type": "number" },
        "dislikes": { "type": "number" }
      },
      "required": ["question", "options", "correctIndex", "animeName", "difficulty", "createdAt", "author", "likes", "dislikes"]
    },
    "GlobalSettings": {
      "title": "GlobalSettings",
      "description": "Global options like slider settings and announcements",
      "type": "object",
      "properties": {
        "sliderLimit": { "type": "number" },
        "sliderSeason": { "type": "string" },
        "sliderSpeed": { "type": "number" },
        "globalAnnouncement": { "type": "string" }
      }
    },
    "GlobalRole": {
      "title": "GlobalRole",
      "description": "Custom administrative or moderator roles assigned to users",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "assignedBy": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "assignedBy", "assignedAt"]
    },
    "Suggestion": {
      "title": "Suggestion",
      "description": "User feedback suggestion or complaint",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["userId", "email", "displayName", "type", "message", "createdAt", "status"]
    },
    "ServerCache": {
      "title": "ServerCache",
      "description": "Multi-layer cloud server cache entry",
      "type": "object",
      "properties": {
        "data": { "type": "object" },
        "expireAt": { "type": "number" }
      },
      "required": ["data", "expireAt"]
    },
    "OtakuLeak": {
      "title": "OtakuLeak",
      "description": "Community anime leaks and news reports",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "source": { "type": "string" },
        "time": { "type": "string" },
         "tag": { "type": "string" },
        "importance": { "type": "string" },
        "likes": { "type": "number" },
        "skulls": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "summary", "source", "time", "tag", "importance", "likes", "skulls", "commentsCount", "createdAt"]
    },
    "UserTierList": {
      "title": "UserTierList",
      "description": "Persistent tier list configuration for an otaku user",
      "type": "object",
      "properties": {
        "placedCharacters": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["placedCharacters", "updatedAt"]
    }
  },
  "firestore": {
    "/server_cache/{cacheId}": {
      "schema": "ServerCache",
      "description": "Distributed cloud server cache database"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Global comments per anime"
    },
    "/recommendations/{recommendationId}": {
      "schema": "Recommendation",
      "description": "Recommendations submitted by users"
    },
    "/ratings/{ratingId}": {
      "schema": "Rating",
      "description": "Ratings submitted by users"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles"
    },
    "/users/{userId}/customLists/{listId}": {
      "schema": "CustomList",
      "description": "User's custom lists"
    },
    "/users/{userId}/animeEntries/{animeId}": {
      "schema": "AnimeEntry",
      "description": "User's anime collection entries with status and metadata"
    },
    "/users/{userId}/tierList/{listId}": {
      "schema": "UserTierList",
      "description": "Stores persistent user anime-character tier lists"
    },
    "/otakuLeaks/{leakId}": {
      "schema": "OtakuLeak",
      "description": "Community shared anime leaks, news, and releases"
    },
    "/gameQuestions/{questionId}": {
      "schema": "GameQuestion",
      "description": "Smart persistent questions pool for games"
    },
    "/animeTrivia/{triviaId}": {
      "schema": "AnimeTrivia",
      "description": "Collection of multiple choice trivia questions about anime"
    },
    "/globalSettings/{settingsId}": {
      "schema": "GlobalSettings",
      "description": "Global settings such as sliders and dynamic main banners"
    },
    "/globalRoles/{userId}": {
      "schema": "GlobalRole",
      "description": "Global roles for access control and moderators selection list"
    },
    "/suggestions/{suggestionId}": {
      "schema": "Suggestion",
      "description": "User feedback suggestions and complaints"
    }
  }
}
